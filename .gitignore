.env.*
!.env.example
*.pem
*.key
*.cer
*.crt
*.p12
*.pfx
*.jks
*.kdbx
secrets.*
*secret*
*credentials*
!**/example*credentials*
.aws/
aws.json
config.json.bak

# Variables de Terraform que típicamente contienen valores reales
*.tfvars
*.tfvars.json
!example.tfvars
!*.example.tfvars

